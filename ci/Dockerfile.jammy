FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*
RUN printf '%s\n' \
    'deb [trusted=yes] https://ppa.launchpadcontent.net/opencpn/opencpn/ubuntu jammy main' \
    > /etc/apt/sources.list.d/opencpn.list
COPY install-debian-build-deps.sh /usr/local/bin/
RUN /usr/local/bin/install-debian-build-deps.sh
