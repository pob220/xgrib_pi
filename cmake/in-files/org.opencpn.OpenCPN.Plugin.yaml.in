id: org.opencpn.OpenCPN.Plugin.${PACKAGE}
runtime: org.opencpn.OpenCPN
runtime-version: ${RUNTIME_VERSION}
sdk: org.freedesktop.Sdk//${SDK_VER}
build-extension: true
separate-locales: false
appstream-compose: false
${finish_args}
${build_options}

# Dependency modules install before the plugin, so their development outputs
# must be removed by manifest-level cleanup rather than per-module cleanup.
cleanup:
  - /include
  - /bin
  - /cmake
  - /lib/*.a
  - /lib/*.la
  - /lib/*.settings
  - /lib/lib*.so*
  - /lib/objects-*
  - /lib/cmake
  - /lib/pkgconfig
  - /share/bash-completion
  - /share/doc
  - /share/eccodes
  - /share/licenses
  - /share/man
  - /share/proj

modules:
${flatpak_extra_modules}
  - name: ${PACKAGE}
    no-autogen: true
    buildsystem: cmake
    builddir: true
    config-opts:
        - -DCMAKE_INSTALL_PREFIX=/app/extensions/${PACKAGE}
        - -DOCPN_FLATPAK_BUILD=ON
        - -DOCPN_TARGET=${OCPN_TARGET}
        - -DSDK_VER=${SDK_VER}
        - -DWX_VER=${WX_VER}
    build-options:
        cflags: -fPIC
        cxxflags: -fPIC -DFLATPAK
        strip: true
    post-install:
       - ctest --output-on-failure
       - /run/build/${PACKAGE}/scripts/test-packaged-helper.sh /app/extensions/${PACKAGE}
    sources:
${flatpak_plugin_source}
